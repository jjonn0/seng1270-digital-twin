/* Buttons */
QPushButton {
    background-color: #3498db; /* blue */
    color: white;
    font-size: 16px;
    font-weight: bold;
    padding: 12px;
    border-radius: 10px;
    min-width: 150px;
}

QPushButton:hover {
    background-color: #2980b9;  /* darker blue on hover */
}

